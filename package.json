{
  "name": "anti",
  "version": "0.0.1",
  "description": "",
  "license": "Apache-2.0",
  "private": true,
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "dependencies": {
    "@mediapipe/face_detection": "^0.4.1646425229",
    "@mediapipe/face_mesh": "~0.4.0",
    "@tensorflow-models/face-detection": "~1.0.0",
    "@tensorflow-models/face-landmarks-detection": "^1.0.6",
    "@tensorflow/tfjs-backend-wasm": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "@tensorflow/tfjs-converter": "^4.22.0",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tweenjs/tween.js": "^18.6.4",
    "blink-detection": "^1.1.3",
    "delaunator": "^5.0.0",
    "perlin-noise-3d": "^0.5.4",
    "scatter-gl": "0.0.8",
    "stats.js": "^0.17.0",
    "three": "^0.131.3",
    "treslib": "^1.10.2",
    "tweenjs": "^1.0.2"
  },
  "scripts": {
    "watch": "cross-env NODE_ENV=development parcel index.html --no-hmr --open",
    "build": "cross-env NODE_ENV=production parcel build index.html --public-url ./",
    "lint": "eslint .",
    "link-local": "yalc link @tensorflow-models/face-landmarks-detection",
    "limpiar": "rm -rf dist .parcel-cache node_modules"
  },
  "alias": {
    "crypto": false
  },
  "staticFiles": [
    {
      "staticPath": "fonts",
      "staticOutPath": "fonts"
    },
    {
      "staticPath": "txt",
      "staticOutPath": "txt"
    },
    {
      "staticPath": "img",
      "staticOutPath": "img"
    },
    {
      "staticPath": "audio",
      "staticOutPath": "audio"
    }
  ],
  "devDependencies": {
    "buffer": "^6.0.3",
    "clang-format": "~1.2.2",
    "cross-env": "^5.2.0",
    "eslint": "^4.19.1",
    "eslint-config-google": "^0.9.1",
    "parcel": "^2.16.4",
    "parcel-reporter-static-files-copy": "^1.5.3",
    "process": "^0.11.10",
    "yalc": "~1.0.0-pre.50"
  },
  "eslintConfig": {
    "extends": "google",
    "rules": {
      "require-jsdoc": 0,
      "valid-jsdoc": 0
    },
    "env": {
      "es6": true
    },
    "parserOptions": {
      "ecmaVersion": 8,
      "sourceType": "module"
    }
  },
  "eslintIgnore": [
    "dist/"
  ]
}
